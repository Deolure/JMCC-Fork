class location {
    inline function __equals__(first: location, second: location) -> number {
        return first.equals(second);
    }
    inline function __not_equals__(first: location, second: location) -> number {
        return first.not_equals(second);
    }
    inline function __add__(first: location, second: location) -> location {
        x,y,z,yaw,pitch = second.get_all_coordinates();
        return variable::shift_all_coordinates(first,x,y,z,yaw,pitch);
    }
    inline function __subtract__(first: location, second: location) -> location {
        x,y,z,yaw,pitch = second.get_all_coordinates()
        variable::subtract(x,[0,x]);
        variable::subtract(y,[0,y]);
        variable::subtract(z,[0,z]);
        variable::subtract(yaw,[0,yaw]);
        variable::subtract(pitch,[0,pitch]);
        return variable::shift_all_coordinates(first,x,y,z,yaw,pitch);
    }
    inline function __multiply__(first: location, second: location) -> location {
        x,y,z,yaw,pitch = first.get_all_coordinates();
        x2,y2,z2,yaw2,pitch2 = second.get_all_coordinates();
        return variable::set_all_coordinates(variable::multiply([x,x2]), variable::multiply([y,y2]), variable::multiply([z,z2]), variable::multiply([yaw,yaw2]), variable::multiply([pitch,pitch2]));
    }
    inline function __divide__(first: location, second: location) -> location {
        x,y,z,yaw,pitch = first.get_all_coordinates();
        x2,y2,z2,yaw2,pitch2 = second.get_all_coordinates();
        return variable::set_all_coordinates(variable::divide([x,x2]), variable::divide([y,y2]), variable::divide([z,z2]), variable::divide([yaw,yaw2]), variable::divide([pitch,pitch2]));
    }
}

class location(location) {
    inline function __set_attribute__(self, key, value) {
        self = self.set_coordinate(value, key);
    }
    inline function __get_attribute__(self, key) {
        return self.get_coordinate(key);
    }
}
class map {
    inline function __equals__(first: map, second: map) -> map {
        return first.equals(second);
    }
    inline function __not_equals__(first: map, second: map) -> map {
        return first.not_equals(second);
    }
    inline function __contains__(first: map, second: text) -> number {
        return first.map_has_key(second);
    }
    inline function __add__(first: map, second: map) -> map {
        return variable::append_map(first, second);
    }
    @getter
    inline function __subscript__(self: map, index: text) -> any {
        return self.get_map_value(index);
    }
    @setter
    inline function __subscript__(self: map, index: text, value: any) -> map {
        self.set_map_value(self,index,value);
    }
}
class array {
    inline function __add__(first: array, second: array) -> array {
        return variable::append_list(first, second);
    }
    inline function __multiply__(first: array, second: number) -> array {
        list = [];
        repeat::multi_times(second) {c ->
            list = variable::append_list(list, first);
        }
        return list;
    }
    inline function __equals__(first: array, second: array) -> array {
        return first.equals(second);
    }
    inline function __not_equals__(first: array, second: array) -> array {
        return first.not_equals(second);
    }
    inline function __greater__(first: array, second: array) -> array {
        length_first = variable::get_list_length(first);
        length_second = variable::get_list_length(second);

        return length_first.greater(length_second);
    }
    inline function __less__(first: array, second: array) -> array {
        length_first = variable::get_list_length(first);
        length_second = variable::get_list_length(second);

        return length_first.less(length_second);
    }
    inline function __greater_or_equals__(first: array, second: array) -> array {
        length_first = variable::get_list_length(first);
        length_second = variable::get_list_length(second);

        return length_first.greater_or_equals(length_second);
    }
    inline function __less_or_equals__(first: array, second: array) -> array {
        length_first = variable::get_list_length(first);
        length_second = variable::get_list_length(second);

        return length_first.less_or_equals(length_second);
    }
    inline function __contains__(first: array, second: text) -> number {
        return first.list_contains_value([second]);
    }

    @getter
    inline function __subscript__(self: array, index: number) -> any {
        return self.get_list_value(index);
    }
    @getter
    inline function __slice__(self: array, first_index: number, second_index: number) -> array {
        return self.trim_list(first_index,second_index);
    }
    @setter
    inline function __subscript__(self: array, index: number, value: any) -> array {
        self.set_list_value(self,index,value)
        return self;
    }
    @setter
    inline function __slice__(self: array,first_index: number, second_index: number, value: array) {
        cdown = 0;
        repeat::on_range(first_index,second_index) { num ->
            val = variable::get_list_value(value,cdown);
            self.set_list_value(self,num,val);
            variable::increment(cdown,1);
        }
    }
}